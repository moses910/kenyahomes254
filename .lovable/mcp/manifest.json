{
  "version": 1,
  "sdk_version": "0.24.0",
  "path": "/functions/v1/mcp",
  "auth": {
    "type": "oauth",
    "issuer": "https://olwvgnulpfqqvgfrxqhg.supabase.co/auth/v1",
    "accepted_audiences": [
      "authenticated"
    ]
  },
  "mcp": {
    "server": {
      "name": "kenyahomes-mcp",
      "version": "0.1.0",
      "title": "KenyaHomes"
    },
    "tools": [
      {
        "name": "search_properties",
        "title": "Search properties",
        "description": "Search published property listings on KenyaHomes. Filter by city, price range, minimum beds/baths, and sale vs rent.",
        "annotations": {
          "readOnlyHint": true,
          "idempotentHint": true,
          "openWorldHint": false
        },
        "inputSchema": {
          "type": "object",
          "properties": {
            "city": {
              "type": "string",
              "description": "City name substring, e.g. 'Nairobi'."
            },
            "min_price": {
              "type": "number",
              "minimum": 0,
              "description": "Minimum price in KES."
            },
            "max_price": {
              "type": "number",
              "minimum": 0,
              "description": "Maximum price in KES."
            },
            "min_beds": {
              "type": "integer",
              "minimum": 0
            },
            "min_baths": {
              "type": "integer",
              "minimum": 0
            },
            "for_rent": {
              "type": "boolean",
              "description": "true = rentals, false = for sale. Omit for both."
            },
            "limit": {
              "type": "integer",
              "minimum": 1,
              "maximum": 50,
              "description": "Max results (default 20)."
            }
          },
          "additionalProperties": false,
          "$schema": "http://json-schema.org/draft-07/schema#"
        },
        "outputSchema": null
      },
      {
        "name": "get_property",
        "title": "Get property details",
        "description": "Fetch full details for a single KenyaHomes property by id.",
        "annotations": {
          "readOnlyHint": true,
          "idempotentHint": true,
          "openWorldHint": false
        },
        "inputSchema": {
          "type": "object",
          "properties": {
            "property_id": {
              "type": "string",
              "format": "uuid",
              "description": "Property UUID."
            }
          },
          "required": [
            "property_id"
          ],
          "additionalProperties": false,
          "$schema": "http://json-schema.org/draft-07/schema#"
        },
        "outputSchema": null
      },
      {
        "name": "list_saved_properties",
        "title": "List my saved properties",
        "description": "List the signed-in user's saved (favourited) properties on KenyaHomes.",
        "annotations": {
          "readOnlyHint": true,
          "idempotentHint": true,
          "openWorldHint": false
        },
        "inputSchema": {
          "$schema": "http://json-schema.org/draft-07/schema#",
          "type": "object",
          "properties": {}
        },
        "outputSchema": null
      },
      {
        "name": "save_property",
        "title": "Save a property",
        "description": "Save (favourite) a property for the signed-in user.",
        "annotations": {
          "readOnlyHint": false,
          "idempotentHint": true,
          "openWorldHint": false
        },
        "inputSchema": {
          "type": "object",
          "properties": {
            "property_id": {
              "type": "string",
              "format": "uuid",
              "description": "Property UUID to save."
            }
          },
          "required": [
            "property_id"
          ],
          "additionalProperties": false,
          "$schema": "http://json-schema.org/draft-07/schema#"
        },
        "outputSchema": null
      },
      {
        "name": "unsave_property",
        "title": "Remove a saved property",
        "description": "Remove a property from the signed-in user's saved list.",
        "annotations": {
          "readOnlyHint": false,
          "destructiveHint": true,
          "idempotentHint": true,
          "openWorldHint": false
        },
        "inputSchema": {
          "type": "object",
          "properties": {
            "property_id": {
              "type": "string",
              "format": "uuid",
              "description": "Property UUID to unsave."
            }
          },
          "required": [
            "property_id"
          ],
          "additionalProperties": false,
          "$schema": "http://json-schema.org/draft-07/schema#"
        },
        "outputSchema": null
      },
      {
        "name": "list_my_listings",
        "title": "List my property listings",
        "description": "For agents: list all property listings owned by the signed-in user, including drafts and unpublished listings.",
        "annotations": {
          "readOnlyHint": true,
          "idempotentHint": true,
          "openWorldHint": false
        },
        "inputSchema": {
          "$schema": "http://json-schema.org/draft-07/schema#",
          "type": "object",
          "properties": {}
        },
        "outputSchema": null
      },
      {
        "name": "list_my_messages",
        "title": "List my messages",
        "description": "List inquiry messages the signed-in user has sent (as a seeker) or received (as the listing agent).",
        "annotations": {
          "readOnlyHint": true,
          "idempotentHint": true,
          "openWorldHint": false
        },
        "inputSchema": {
          "type": "object",
          "properties": {
            "role": {
              "type": "string",
              "enum": [
                "sent",
                "received",
                "all"
              ],
              "description": "Filter by role (default 'all')."
            },
            "limit": {
              "type": "integer",
              "minimum": 1,
              "maximum": 100
            }
          },
          "additionalProperties": false,
          "$schema": "http://json-schema.org/draft-07/schema#"
        },
        "outputSchema": null
      }
    ]
  }
}
